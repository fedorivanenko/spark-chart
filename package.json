{
	"name": "braille-charts",
	"version": "0.1.0",
	"private": true,
	"description": "shadcn-style braille chart components for React",
	"type": "module",
	"scripts": {
		"build": "tsup && cp src/styles/globals.css dist/styles.css",
		"check": "biome check .",
		"dev": "vite --config examples/demo/vite.config.ts",
		"format": "biome check --write . && prettier --write README.md",
		"typecheck": "tsc --noEmit"
	},
	"keywords": [
		"shadcn",
		"charts",
		"braille",
		"react"
	],
	"peerDependencies": {
		"clsx": "^2.1.1",
		"react": "^18.2.0 || ^19.0.0",
		"react-dom": "^18.2.0 || ^19.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.0",
		"@types/react": "^18.3.12",
		"@types/react-dom": "^18.3.1",
		"@vitejs/plugin-react": "^6.0.2",
		"prettier": "^3.8.4",
		"tsup": "^8.3.5",
		"typescript": "^5.6.3",
		"vite": "^8.0.16"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./styles.css": "./dist/styles.css"
	},
	"files": [
		"dist"
	]
}
